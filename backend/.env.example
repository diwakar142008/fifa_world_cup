# ═══════════════════════════════════════════════════════════════
# StadiumMind AI - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and customize for your environment.
# NEVER commit the actual .env file to version control.
# ═══════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
APP_NAME=StadiumMind AI
APP_VERSION=1.0.0
API_PREFIX=/api/v1
DEBUG=false
TESTING=false

# ─── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","https://stadium-mind.ai"]

# ─── Database (PostgreSQL / Supabase) ─────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/stadiummind
DATABASE_ECHO=false
REDIS_URL=redis://localhost:6379/0

# ─── Authentication & Security ────────────────────────────────
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-to-a-secure-random-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_MINUTES=10080
CSRF_SECRET_KEY=
SESSION_TIMEOUT_MINUTES=60
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ─── AI Services ──────────────────────────────────────────────
# At least one API key is required for AI features.
# Priority order: OpenAI > Anthropic > Gemini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# ─── External APIs ────────────────────────────────────────────
MAPBOX_TOKEN=
WEATHER_API_KEY=
METRO_API_KEY=

# ─── Mock Mode ────────────────────────────────────────────────
# When true, uses simulated data instead of real database/AI
USE_MOCK_DATA=true
MOCK_UPDATE_INTERVAL_SECONDS=5

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(levelname)-8s | %(name)s | %(message)s
LOG_TO_FILE=false